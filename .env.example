# 栖途 NestWay - Supabase 环境配置（示例）
# 复制此文件为 .env，填入实际值即可
#
# 注意：.env 已在 .gitignore 中，不会被提交到 Git

# Supabase 项目 URL（公开）
SUPABASE_URL=https://fbnctnhjcjkbmmvcuqxh.supabase.co

# Supabase Anon Key（公开密钥，用于客户端 App）
# 在 Supabase Dashboard > Settings > API 中获取
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZibmN0bmhqY2prYm1tdmN1cXhoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg5MTUwODQsImV4cCI6MjA5NDQ5MTA4NH0.YvPfjSifHCYpABVNU8XaGaAC6gsBun8eSGBa-qX7p04

# Supabase Service Role Key（服务端密钥）
# 切勿在此填入！切勿提交到 Git！
# 仅在本机 .env 中配置，用于执行数据库迁移脚本
# SUPABASE_SERVICE_KEY=仅在本地.env配置，勿提交

# -------------------------------------------
# 阿里云短信服务（用于 Supabase Edge Function）
# 部署方式: supabase secrets set --env-file .env
# Edge Function: supabase/functions/send-sms-alicloud/
# -------------------------------------------

# 阿里云 AccessKey（建议使用 RAM 子账号，仅授权 dysmsapi:SendSms）
# ALIBABA_ACCESS_KEY_ID=LTAI5txxxx
# ALIBABA_ACCESS_KEY_SECRET=xxxxxxxx

# 短信签名（需在阿里云短信控制台审核通过）
# ALIBABA_SMS_SIGN_NAME=栖途

# 短信模板CODE（模板需包含 ${code} 变量，如"您的验证码是${code}"）
# ALIBABA_SMS_TEMPLATE_CODE=SMS_123456789

# Edge Function 访问密钥（两个 Edge Function 共用）
# FUNCTION_SECRET=nestway-sos-sms-2026

# SOS 短信模板CODE（模板需包含 ${name}、${location}、${coords} 变量）
# 阿里云模板示例："紧急求助：${name}发起了SOS求助。位置：${location}(${coords})。请确认安全！"
# ALIBABA_SOS_TEMPLATE_CODE=SMS_987654321
